				<Parameter Name="ID" Value="&quot;opc_ua[WRITE;/Objects/Counter]&quot;"/>
			</FB>
			<FB Name="SUBSCRIBE_1" Type="iec61499::net::SUBSCRIBE_1" x="800" y="-300">
