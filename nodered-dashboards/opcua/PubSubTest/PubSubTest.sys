			</FB>
			<FB Name="E_PERMIT" Type="iec61499::events::E_PERMIT" x="1900" y="-100">
			</FB>
			<FB Name="SUBSCRIBE_2" Type="iec61499::net::SUBSCRIBE_1" x="300" y="900">
				<Parameter Name="QI" Value="TRUE"/>
				<Parameter Name="ID" Value="&quot;opc_ua[READ;/Objects/Stop]&quot;"/>
			</FB>
			<FB Name="E_PERMIT_1" Type="iec61499::events::E_PERMIT" x="2000" y="1100">
			</FB>
			<FB Name="E_PERMIT_2" Type="iec61499::events::E_PERMIT" x="3700" y="-600">
			</FB>
			<EventConnections>
				<Connection Source="E_CYCLE.EO" Destination="E_CTU.CU"/>
				<Connection Source="E_CTU.CUO" Destination="PUBLISH_1.REQ" dx1="186.67"/>
				<Connection Source="SUBSCRIBE_1.IND" Destination="E_PERMIT.EI" dx1="100"/>
				<Connection Source="E_PERMIT.EO" Destination="E_CYCLE.START" dx1="166.67"/>
				<Connection Source="E_PERMIT_1.EO" Destination="E_CYCLE.STOP" dx1="120"/>
				<Connection Source="SUBSCRIBE_2.IND" Destination="E_PERMIT_1.EI" dx1="146.67"/>
				<Connection Source="SUBSCRIBE_1.INITO" Destination="SUBSCRIBE_2.INIT" dx1="80" dx2="80" dy="700"/>
				<Connection Source="SUBSCRIBE_2.INITO" Destination="PUBLISH_1.INIT" dx1="1300"/>
				<Connection Source="E_CTU.CUO" Destination="E_PERMIT_2.EI" dx1="80" dx2="80" dy="400"/>
				<Connection Source="E_PERMIT_2.EO" Destination="E_CTU.R" dx1="80" dx2="80" dy="-346.67"/>
			</EventConnections>
			<DataConnections>
				<Connection Source="E_CTU.CV" Destination="PUBLISH_1.SD_1" dx1="186.67"/>
				<Connection Source="SUBSCRIBE_1.RD_1" Destination="E_PERMIT.PERMIT" dx1="100"/>
				<Connection Source="SUBSCRIBE_2.RD_1" Destination="E_PERMIT_1.PERMIT" dx1="146.67"/>
				<Connection Source="E_CTU.Q" Destination="E_PERMIT_2.PERMIT" dx1="80" dx2="80" dy="346.67"/>
			</DataConnections>
		</SubAppNetwork>
	</Application>
	<Device Name="FORTE_PC" Type="iec61499::system::FORTE_PC" x="2180" y="853.33">
