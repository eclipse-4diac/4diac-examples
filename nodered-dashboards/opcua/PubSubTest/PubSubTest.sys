					<Connection Source="START.COLD" Destination="PubSubTestApp.SUBSCRIBE_1.INIT" dx1="93.33"/>
				</EventConnections>
			</FBNetwork>
		</Resource>
	</Device>
	<Segment Name="Ethernet" Type="iec61499::system::Ethernet" x="2973.33" y="406.67" dx1="2000">
		<Attribute Name="Color" Type="STRING" Value="68,233,181"/>
	</Segment>
	<Mapping From="PubSubTestApp.E_CYCLE" To="FORTE_PC.EMB_RES"/>
